# PostgreSQL connection string (required)
DATABASE_URL=postgres://trading_user:change_me@localhost:5432/trading?sslmode=disable

#PostgreSQL Password
POSTGRES_PASSWORD=password

# Trading mode: paper or live (default: paper)
MODE=paper

# Dashboard listen address (default: :8080)
HTTP_ADDR=:8080

# Bearer token guarding the /admin/* endpoints (required)
ADMIN_TOKEN=change_me_to_a_long_random_string

# Kalshi API base URL (default: demo sandbox)
KALSHI_BASE_URL=https://external-api.demo.kalshi.co/trade-api/v2
